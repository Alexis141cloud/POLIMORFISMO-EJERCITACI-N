class Animal:
    def hacerSonido(self):
        raise NotImplementedError("Este método debe ser sobrescrito por las subclases")

class Perro(Animal):
    def __init__(self, nombre):
        self.nombre = nombre
    
    def hacerSonido(self):
        return "Guau"

class Gato(Animal):
    def __init__(self, nombre):
        self.nombre = nombre
    
    def hacerSonido(self):
        return "Miau"


def main():
    animales = [
        Perro("Rex"),
        Gato("Michi"),
        Perro("Firulais"),
        Gato("Bigotes")
    ]
    
    for animal in animales:
        print(f"{animal.nombre} ({animal.__class__.__name__}) dice: {animal.hacerSonido()}")

if __name__ == "__main__":
    main()
